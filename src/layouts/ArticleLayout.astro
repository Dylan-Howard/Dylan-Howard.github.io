---
// src/layouts/ArticleLayout.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ArrowLink from '@/components/ArrowLink.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  readingTime?: string;
  tags?: string[];
  ogImage?: string;
}

const { title, description, date, readingTime, tags = [], ogImage } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${title} — Portfolio`} description={description} ogImage={ogImage}>
  <Header />

  <main class="article-main">
    <div class="container container--narrow">

      <!-- Back nav -->
      <nav class="article-back">
        <ArrowLink href="/writing" label="Writing" direction="left" />
      </nav>

      <!-- Article header -->
      <header class="article-header fade-up">
        <div class="article-meta">
          <span class="section-label">{formattedDate}</span>
          {readingTime && <span class="section-label article-meta__sep">{readingTime} min read</span>}
        </div>
        <h1 class="article-title">{title}</h1>
        {description && <p class="article-lead">{description}</p>}
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </header>

      <hr class="rule article-rule" />

      <!-- MDX content -->
      <article class="prose fade-up" style="animation-delay: 120ms;">
        <slot />
      </article>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* ── Article layout ───────────────────────────────────── */
  .article-main {
    padding-top: var(--space-20);
    padding-bottom: var(--space-24);
  }

  .article-back {
    margin-bottom: var(--space-12);
  }

  .article-header {
    margin-bottom: var(--space-8);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .article-meta__sep::before {
    content: '·';
    margin-right: var(--space-6);
  }

  .article-title {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .article-lead {
    font-family: var(--font-body);
    font-size: var(--text-md);
    font-style: italic;
    color: var(--ink-soft);
    max-width: 54ch;
    line-height: 1.6;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-6);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    border: 1px solid var(--rule);
    padding: 2px var(--space-3);
    border-radius: 2px;
  }

  .article-rule {
    margin-block: var(--space-8);
  }

  /* ── Prose styles ─────────────────────────────────────── */
  .prose {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--ink-soft);
  }

  .prose p { margin-bottom: var(--space-6); }

  .prose h2 {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    color: var(--ink);
  }

  .prose h3 {
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    color: var(--ink);
  }

  .prose h4 {
    font-size: var(--text-md);
    font-weight: 500;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    color: var(--ink);
  }

  .prose strong {
    font-weight: 500;
    color: var(--ink);
  }

  .prose em { font-style: italic; }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-dim);
    transition: text-decoration-color var(--duration-fast);
  }

  .prose a:hover {
    text-decoration-color: var(--accent);
  }

  .prose ul, .prose ol {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .prose ul { list-style: disc; }
  .prose ol { list-style: decimal; }

  .prose li {
    margin-bottom: var(--space-2);
  }

  .prose blockquote {
    border-left: 2px solid var(--accent);
    padding-left: var(--space-6);
    margin-left: 0;
    margin-block: var(--space-8);
    font-style: italic;
    color: var(--ink-muted);
  }

  .prose code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--parchment);
    padding: 1px 6px;
    border-radius: 3px;
    border: 1px solid var(--rule);
    color: var(--accent);
  }

  .prose pre {
    background: var(--ink);
    color: #e8e4dc;
    padding: var(--space-6);
    border-radius: 4px;
    overflow-x: auto;
    margin-block: var(--space-8);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--rule);
    margin-block: var(--space-12);
  }

  .prose img {
    width: 100%;
    border-radius: 4px;
    margin-block: var(--space-8);
  }

  .prose figure {
    margin-block: var(--space-8);
  }

  .prose figcaption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-muted);
    margin-top: var(--space-3);
    text-align: center;
    letter-spacing: 0.05em;
  }
</style>
