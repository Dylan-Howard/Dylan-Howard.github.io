---
// src/layouts/ResumeLayout.astro
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';

interface Props {
  title:       string;
  description: string;
  pdfUrl:      string;
  lastUpdated: Date;
}

const { title, description, pdfUrl, lastUpdated } = Astro.props;

const updatedFormatted = lastUpdated.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// JSON-LD for the resume page — use ProfilePage schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type':    'ProfilePage',
  name:        `${SITE.name} — Résumé`,
  url:         `${SITE.url}/resume`,
  about: {
    '@type':   'Person',
    name:       SITE.name,
    jobTitle:   SITE.role,
    url:        SITE.url,
    sameAs:     [SITE.links.github, SITE.links.linkedin],
  },
  dateModified: lastUpdated.toISOString(),
};
---

<BaseLayout
  title={`${title} — ${SITE.name}`}
  description={description}
  ogType="profile"
  updatedAt={lastUpdated}
  jsonLd={jsonLd}
>
  <Header />

  <main id="main-content" class="resume-page">
    <div class="container container--narrow">

      <!-- Page header -->
      <header class="resume-header fade-up">
        <div class="resume-header__top">
          <div>
            <span class="section-label">Résumé</span>
            <h1 class="resume-header__name">{SITE.name}</h1>
            <p class="resume-header__role">{SITE.role}</p>
          </div>

          <div class="resume-header__actions">
            <a
              href={pdfUrl}
              class="resume-download"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Download résumé as PDF (opens in new tab)"
            >
              <span>Download PDF</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 1v8M3.5 5.5L7 9l3.5-3.5M1 11h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <p class="resume-header__updated section-label">
              Updated {updatedFormatted}
            </p>
          </div>
        </div>

        <div class="resume-header__contact">
          <a href={`mailto:${SITE.email}`} class="resume-contact-link">{SITE.email}</a>
          <span class="resume-contact-sep" aria-hidden="true">·</span>
          <a href={SITE.links.github}   class="resume-contact-link" target="_blank" rel="noopener">GitHub</a>
          <span class="resume-contact-sep" aria-hidden="true">·</span>
          <a href={SITE.links.linkedin} class="resume-contact-link" target="_blank" rel="noopener">LinkedIn</a>
          <span class="resume-contact-sep" aria-hidden="true">·</span>
          <span class="resume-contact-link">{SITE.location}</span>
        </div>
      </header>

      <hr class="rule resume-header__rule fade-up" style="animation-delay:80ms" />

      <!-- MDX content -->
      <article class="prose resume-prose fade-up" style="animation-delay:120ms">
        <slot />
      </article>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .resume-page {
    padding-top: var(--space-20);
    padding-bottom: var(--space-24);
  }

  /* Header */
  .resume-header {
    padding-top: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .resume-header__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .resume-header__name {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-4xl));
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-top: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .resume-header__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    max-width: none;
  }

  /* Download button */
  .resume-header__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .resume-download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border: 1px solid var(--ink);
    padding: var(--space-2) var(--space-4);
    transition: background var(--dur-fast), border-color var(--dur-fast);
    text-decoration: none;
    white-space: nowrap;
  }

  .resume-download:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .resume-header__updated {
    color: var(--ink-muted);
    max-width: none;
    text-align: right;
  }

  /* Contact line */
  .resume-header__contact {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .resume-contact-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--dur-fast);
  }

  a.resume-contact-link:hover { color: var(--accent); }

  .resume-contact-sep {
    color: var(--rule);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .resume-header__rule {
    margin-bottom: var(--space-8);
  }

  /* Prose overrides for resume context */
  .resume-prose :global(h2) {
    font-size: var(--text-lg);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--space-2);
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
  }

  .resume-prose :global(h3) {
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--ink);
    margin-top: var(--space-8);
    margin-bottom: 0;
  }

  .resume-prose :global(h3 + p),
  .resume-prose :global(h3 + strong) {
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-style: normal;
    display: block;
    margin-top: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .resume-prose :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: var(--space-6);
  }

  .resume-prose :global(ul li) {
    padding-left: var(--space-6);
    position: relative;
    margin-bottom: var(--space-2);
  }

  .resume-prose :global(ul li::before) {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--rule);
    font-family: var(--font-mono);
  }

  .resume-prose :global(strong) {
    color: var(--ink);
    font-weight: 500;
  }

  .resume-prose :global(hr) {
    margin-block: var(--space-8);
    border-top-color: var(--rule);
  }

  @media (max-width: 600px) {
    .resume-header__top { flex-direction: column; gap: var(--space-6); }
    .resume-header__actions { align-items: flex-start; }
    .resume-header__updated { text-align: left; }
  }
</style>
