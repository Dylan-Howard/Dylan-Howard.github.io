---
// src/components/About.astro
import ArrowLink from './ArrowLink.astro';
import { SITE, MAILTO } from '../config/site';
import SectionDivider from './SectionDivider.astro';
---

<section id="about" class="about-section" aria-labelledby="about-heading">
  <div class="container">

    <SectionDivider numeral="02" label="About" />

    <div class="about-grid">

      <!-- Main copy -->
      <div class="about-body-col">
        <h2 class="about-heading" id="about-heading">
          I build systems<br />
          <em>that people depend on.</em>
        </h2>

        <div class="about-copy">
          <p>
            I am a Software Engineer at Warren County Public Schools, where I&rsquo;ve spent four years 
            architecting the identity, data, and operational infrastructure for 20,000+&nbsp;students 
            and staff. My work is defined by a core conviction: <em>the best engineer is one who 
            aims to serve the team and the users.</em> I aim place the needs of my coworkers first. 
            Whether that involves building custom internal tools to 10x our technicians' 
            productivity or stepping into non-development roles to ensure a project crosses the 
            finish line, I prioritize the collective success of the mission over individual credit.
          </p>
          <p>
            The reach of my work has scaled significantly: a provisioning system I designed for a 
            single district evolved into a statewide platform serving 750,000+&nbsp;users. This 
            effort was recognized with the <em>Stillwell&nbsp;Award&nbsp;(2022)</em> and a featured 
            speaking engagement at the <em>Identity Automation User Group (2025)</em>.
          </p>
          <p>
            Driven by <em>User Empathy</em>, I approach engineering by identifying the &ldquo;right tool 
            for the task&rdquo;—whether that&rsquo;s leveraging Astro for performance-first templating or 
            implementing <em>O(m)</em> sync strategies to optimize Azure egress. I am <em>always a 
            learner</em>, currently expanding my expertise in Go-based microservices and distributed 
            system patterns.
          </p>
          <h3>The Path So Far</h3>
          <ul class="about-copy-list">
            <li class="about-copy-item">
              <span><em>SaaS Engineering:</em> Architected and launched a franchise banking platform on AWS, managing everything from polyglot data consistency to CI/CD.</span>
            </li>
            <li class="about-copy-item">
              <span><em>Internal Tooling:</em> Developed custom user-impersonation and "Step-Up" authentication tools that cut IT helpdesk volume and boosted technician productivity.</span>
            </li>
            <li class="about-copy-item">
              <span><em>Legacy Modernization:</em> Rebuilt real-time data aggregators for the Kentucky Mesonet, handling high-velocity sensor data from 50+ stations.</span>
            </li>
          </ul>
          <p>
        </div>

        <div class="about-links">
          <ArrowLink href={SITE.links.github}                        label="GitHub"   />
          <ArrowLink href={SITE.links.linkedin}    label="LinkedIn" />
          <ArrowLink href="/#contact"                                               label="Get in touch" />
        </div>
      </div>

      <!-- Sidebar facts -->
      <aside class="about-aside" aria-label="Quick facts">
        <dl class="facts-card">
          <div class="fact">
            <dt class="section-label">Current role</dt>
            <dd class="fact__val">Software Engineer, WCPS</dd>
          </div>
          <div class="fact">
            <dt class="section-label">Location</dt>
            <dd class="fact__val">Bowling Green, KY</dd>
          </div>
          <div class="fact">
            <dt class="section-label">Focus</dt>
            <dd class="fact__val fact__val--accent">Full-Stack .NET &amp; Next.js / Data Infrastructure</dd>
          </div>
          <div class="fact">
            <dt class="section-label">Education</dt>
            <dd class="fact__val fact__val--sm">
              B.S. Computer Science<br />
              <span class="fact__sub">Western Kentucky Univ. &rsquo;18</span>
            </dd>
          </div>
        </dl>

        <div class="recognition-block" aria-label="Awards and speaking">
          <p class="section-label recognition-block__label">Recognition &amp; Speaking</p>
          <ul class="recognition-list">
            <li class="recognition-item">
              <span class="recognition-item__mark" aria-hidden="true">◆</span>
              <span>Stillwell Award — KY DOE Office of Educational Technology, 2022</span>
            </li>
            <li class="recognition-item">
              <span class="recognition-item__mark" aria-hidden="true">◆</span>
              <span>Speaker &amp; Panelist — Identity Automation User Group, June 2025</span>
            </li>
          </ul>
        </div>
      </aside>

    </div>
  </div>
</section>

<style>
  .about-section {
    padding-bottom: var(--space-24);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-16);
    align-items: start;
  }

  /* Heading */
  .about-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: var(--space-8);
  }

  .about-heading em {
    font-style: italic;
    color: var(--accent);
  }

  /* Copy */
  .about-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .about-copy p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.82;
    color: var(--ink-soft);
    max-width: 58ch;
  }

  .about-copy-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-8);
  }

  .about-copy-item {
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--ink-soft);
    line-height: 1.82;
    max-width: 58ch;
  }

  .about-copy-item::before {
    content: "◆";
    flex-shrink: 0;
    margin-top: 0.55em;
    font-size: 0.7rem;
    font-style: normal;
  }

  /* Links row */
  .about-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  /* Sidebar */
  .about-aside {
    position: sticky;
    top: calc(57px + var(--space-8)); /* header height + breathing room */
  }

  /* Facts card */
  .facts-card {
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
  }

  .fact {
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .fact:last-child {
    border-bottom: none;
  }

  .fact__val {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink);
    line-height: 1.3;
  }

  .fact__val--accent {
    color: var(--accent);
    font-style: italic;
  }

  .fact__val--sm {
    font-size: var(--text-md);
  }

  .fact__sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-muted);
    letter-spacing: 0.06em;
  }

  /* Recognition block */
  .recognition-block {
    margin-top: 1px; /* gap-less join to facts-card */
    border: 1px solid var(--rule);
    border-top: none;
    padding: var(--space-4) var(--space-6);
    background: var(--parchment);
  }

  .recognition-block__label {
    display: block;
    margin-bottom: var(--space-3);
  }

  .recognition-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
  }

  .recognition-item {
    display: flex;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: 1.55;
    font-style: italic;
  }

  .recognition-item__mark {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
    font-style: normal;
    font-size: 0.7rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .about-aside {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .about-links {
      gap: var(--space-6);
    }
  }
</style>
