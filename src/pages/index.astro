---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import About from '../components/About.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { SITE, SITE_TITLE } from '../config/site';

// Load and sort work entries from content collections
const allWork: CollectionEntry<'work'>[] = await getCollection('work');
const projects = allWork.sort((a, b) => a.data.order - b.data.order);

// Map content collection entries to ProjectCard props
// Impact stats are defined here (alongside the card data)
// because they're presentational, not stored in MDX frontmatter.
const projectCards = projects.map((p) => ({
  slug:        p.slug,
  title:       p.data.title,
  description: p.data.description,
  type:        p.data.type,
  year:        p.data.year,
  stack:       p.data.stack,
  href:        p.data.href,
  featured:    p.data.featured,
  awards:      p.data.awards,
}));

// Impact stats keyed by slug — keeps MDX frontmatter clean
const impactMap: Record<string, { value: string; label: string }[]> = {
  'kentucky-iam-platform': [
    { value: '750k+', label: 'Users managed'             },
    { value: '171',   label: 'Districts served'          },
    { value: '99.9%', label: 'Uptime SLA'                },
    { value: '80h',   label: 'Manual effort saved / mo.' },
  ],
  'identity-monitoring-platform': [
    { value: '1.5→0.6', label: 'Avg. resolution (days)'  },
    { value: '−60%',    label: 'Resolution time'          },
  ],
  'franchise-banking-saas': [
    { value: '$18M+', label: 'Transactions processed'    },
    { value: '−1 day', label: 'Incident response time'   },
  ],
  'enterprise-data-pipeline': [
    { value: '40+',  label: 'Systems integrated'         },
    { value: '−82%', label: 'Network utilization'        },
    { value: '−30%', label: 'Server load'                },
  ],
};

const visibilityMap: Record<string, string> = {
  'kentucky-iam-platform':     'Production · State Platform',
  'identity-monitoring-platform': '',
  'franchise-banking-saas':    'Commercial · NDA',
  'enterprise-data-pipeline':  'Production · Internal',
  'data-validation-platform':  'Production · Internal',
  'koine-greek-learning-platform': '',
};
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE.description}
>
  <Header />

  <main id="main-content">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <Hero />

    <!-- ── Work ──────────────────────────────────────────── -->
    <section id="work" aria-labelledby="work-heading">
      <div class="container">

        <SectionDivider numeral="01" label="Selected Work" />

        <div class="work-intro fade-up">
          <h2 class="work-title" id="work-heading">Work</h2>
          <p class="work-sub">
            Six projects across identity engineering, data infrastructure,
            and commercial full-stack development — each chosen because it
            posed a non-trivial problem worth explaining.
          </p>
        </div>

        <div class="projects-grid" role="list">
          {projectCards.map((p, i) => (
            <ProjectCard
              {...p}
              index={i}
              impact={impactMap[p.slug] ?? []}
              visibility={visibilityMap[p.slug] ?? ''}
              award={p.awards?.[0]
                ? p.awards[0].split('—')[0].trim()   /* shorten for card badge */
                : undefined}
            />
          ))}
        </div>

      </div>
    </section>

    <!-- ── Skills ─────────────────────────────────────────── -->
    <SkillsGrid />

    <!-- ── About ──────────────────────────────────────────── -->
    <About />

    <!-- ── Contact ────────────────────────────────────────── -->
    <ContactForm />

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Work section */
  .work-intro {
    margin-bottom: var(--space-8);
  }

  .work-title {
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }

  .work-sub {
    font-family: var(--font-body);
    font-size: var(--text-md);
    font-style: italic;
    color: var(--ink-soft);
    max-width: 50ch;
    line-height: 1.65;
  }

  /* Projects grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    /* TODO: Revise gap style */
    /* gap: 1px; */
    /* background: var(--rule); */
    /* border: 1px solid var(--rule); */
    gap: 6px;
    margin-bottom: var(--space-24);
  }

  /* Featured (full-width) card spans both columns */
  .projects-grid :global(.project-cell--full) {
    grid-column: 1 / -1;
  }

  @media (max-width: 780px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid :global(.project-cell--full) {
      grid-column: 1;
    }
  }
</style>
