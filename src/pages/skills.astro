---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Typography from '../components/Typography.astro';
import Tag from '../components/Tag.astro';

const projects = await getCollection('projects');

// Extract and count technologies from projects
const techCount = {};
projects.forEach(project => {
  project.data.technologies?.forEach(tech => {
    techCount[tech] = (techCount[tech] || 0) + 1;
  });
});

const skillCategories = {
  "Frontend Development": {
    skills: ["React", "TypeScript", "Next.js", "Astro", "HTML/CSS", "JavaScript"],
    description: "Building responsive, accessible user interfaces with modern frameworks and best practices."
  },
  "Backend Development": {
    skills: ["C#", ".NET", "Node.js", "Python", "Go", "RESTful APIs"],
    description: "Designing scalable server architectures and robust API systems."
  },
  "Database & Storage": {
    skills: ["SQL Server", "PostgreSQL", "MongoDB", "Azure Cosmos DB", "Redis"],
    description: "Data modeling, optimization, and management across SQL and NoSQL systems."
  },
  "Cloud & DevOps": {
    skills: ["Azure", "AWS", "Docker", "Azure Functions", "CI/CD", "Git"],
    description: "Cloud-native development and automated deployment pipelines."
  },
  "Specialized": {
    skills: ["Identity Management", "Security", "Performance Optimization", "System Integration"],
    description: "Domain expertise in enterprise systems and security implementations."
  }
};

const proficiencyLevels = {
  "Expert": ["React", "C#", ".NET", "TypeScript", "SQL Server", "Azure"],
  "Advanced": ["Next.js", "Node.js", "Python", "PostgreSQL", "Docker", "Git"],
  "Intermediate": ["Go", "MongoDB", "AWS", "Redis", "Astro"],
  "Learning": ["Kubernetes", "GraphQL", "Machine Learning"]
};
---

<Layout title="Skills & Technologies" description="Technical skills and expertise of Dylan Howard, including frontend, backend, cloud technologies, and specialized domain knowledge.">
  <Section id="skills-overview" title="Technical Expertise">
    <div class="skills-intro">
      <Typography size="large" variant="body">
        My technical expertise spans full-stack development with a focus on enterprise applications, 
        identity management systems, and educational technology. I believe in choosing the right tool 
        for each project while maintaining a strong foundation in proven technologies.
      </Typography>
    </div>
  </Section>

  <Section id="skill-categories" title="Core Competencies">
    <div class="categories-grid">
      {Object.entries(skillCategories).map(([category, data]) => (
        <div class="category-card">
          <Typography component="h3" size="medium" variant="title" bottomGutter="small">
            {category}
          </Typography>
          <Typography size="medium" variant="body" class="category-description">
            {data.description}
          </Typography>
          <div class="skill-tags">
            {data.skills.map((skill) => (
              <div class="skill-tag-wrapper">
                <Tag type={skill}>{skill}</Tag>
                {techCount[skill] && (
                  <span class="project-count">{techCount[skill]} projects</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section id="proficiency-levels" title="Proficiency Levels">
    <div class="proficiency-grid">
      {Object.entries(proficiencyLevels).map(([level, skills]) => (
        <div class="proficiency-card">
          <Typography component="h3" size="medium" variant="title" bottomGutter="small">
            {level}
          </Typography>
          <div class="proficiency-skills">
            {skills.map((skill) => (
              <Tag type={skill}>{skill}</Tag>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section id="technology-philosophy" title="Technology Philosophy">
    <div class="philosophy-content">
      <div class="philosophy-item">
        <Typography component="h3" size="medium" variant="title">
          Right Tool for the Job
        </Typography>
        <Typography size="medium" variant="body">
          I believe in selecting technologies based on project requirements, team expertise, 
          and long-term maintainability rather than following trends.
        </Typography>
      </div>

      <div class="philosophy-item">
        <Typography component="h3" size="medium" variant="title">
          Performance & Security First
        </Typography>
        <Typography size="medium" variant="body">
          Every technical decision considers performance implications and security best practices, 
          especially when building enterprise-scale applications.
        </Typography>
      </div>

      <div class="philosophy-item">
        <Typography component="h3" size="medium" variant="title">
          Continuous Learning
        </Typography>
        <Typography size="medium" variant="body">
          Technology evolves rapidly. I stay current through hands-on projects, documentation, 
          and community engagement while maintaining expertise in core technologies.
        </Typography>
      </div>
    </div>
  </Section>

  <Section id="recent-focus" title="Current Learning Focus">
    <div class="learning-content">
      <Typography size="large" variant="body">
        Currently exploring advanced cloud architectures, container orchestration with Kubernetes, 
        and modern frontend patterns with Astro and server-side rendering optimization.
      </Typography>
      
      <div class="learning-tags">
        {proficiencyLevels.Learning.map((skill) => (
          <Tag type={skill}>{skill}</Tag>
        ))}
      </div>
    </div>
  </Section>
</Layout>

<style>
  .skills-intro {
    max-width: 800px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .category-card {
    padding: 2rem;
    border-radius: var(--dlh-theme-shape-corner-medium);
    background: var(--dlh-theme-color-surface-container);
    border: 1px solid var(--dlh-theme-color-outline-variant);
  }

  .category-description {
    margin-bottom: 1.5rem;
    color: var(--dlh-theme-color-on-surface-variant);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill-tag-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .project-count {
    font-size: 0.75rem;
    color: var(--dlh-theme-color-on-surface-variant);
    font-weight: 500;
  }

  .proficiency-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .proficiency-card {
    padding: 1.5rem;
    border-radius: var(--dlh-theme-shape-corner-medium);
    background: var(--dlh-theme-color-surface-container);
  }

  .proficiency-card h3 {
    color: var(--dlh-theme-color-primary);
  }

  .proficiency-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .philosophy-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .philosophy-item {
    padding: 1.5rem;
    border-radius: var(--dlh-theme-shape-corner-medium);
    background: var(--dlh-theme-color-surface-container);
  }

  .philosophy-item h3 {
    margin-bottom: 1rem;
    color: var(--dlh-theme-color-primary);
  }

  .learning-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .learning-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>