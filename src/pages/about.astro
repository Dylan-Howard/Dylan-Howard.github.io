---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Typography from '../components/Typography.astro';
import Tag from '../components/Tag.astro';

const experience = await getCollection('experience');
experience.sort((a, b) => new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime());

const skills = {
  "Frontend": ["React", "TypeScript", "Next.js", "Astro", "HTML/CSS"],
  "Backend": ["C#", ".NET", "Node.js", "Python", "SQL"],
  "Cloud & DevOps": ["Azure", "AWS", "Docker", "CI/CD"],
  "Databases": ["SQL Server", "PostgreSQL", "MongoDB"],
  "Tools": ["Git", "Visual Studio", "VS Code", "Figma"]
};
---

<Layout title="About Dylan Howard" description="Software Engineer specializing in full-stack development, identity management systems, and educational technology solutions.">
  <Section id="about-intro" title="About Me">
    <div class="about-content">
      <Typography size="large" variant="body">
        I'm a passionate software engineer with expertise in full-stack development, specializing in identity management systems and educational technology. Currently serving as a Software Engineer at Warren County Public Schools, I design and build enterprise-scale applications that serve thousands of users.
      </Typography>
      
      <Typography size="large" variant="body">
        My approach combines technical excellence with strong stakeholder collaboration, ensuring that complex systems meet real-world needs. I'm particularly drawn to projects that involve system integration, performance optimization, and creating intuitive user experiences for technical and non-technical users alike.
      </Typography>

      <Typography size="large" variant="body">
        When I'm not coding, I enjoy exploring new technologies, contributing to open-source projects, and mentoring junior developers. I believe in continuous learning and staying current with industry best practices.
      </Typography>
    </div>
  </Section>

  <Section id="experience" title="Professional Experience">
    <div class="experience-timeline">
      {experience.map((job) => (
        <div class="experience-item">
          <div class="experience-header">
            <Typography component="h3" size="medium" variant="title">
              {job.data.role}
            </Typography>
            <Typography size="medium" variant="body" class="company">
              {job.data.company}
            </Typography>
            <Typography size="small" variant="body" class="duration">
              {job.data.startDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })} - 
              {job.data.endDate ? job.data.endDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : 'Present'}
            </Typography>
          </div>
          <Typography size="medium" variant="body">
            {job.data.description}
          </Typography>
          <div class="tech-tags">
            {job.data.technologies.map((tech) => (
              <Tag type={tech}>{tech}</Tag>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section id="skills" title="Technical Skills">
    <div class="skills-grid">
      {Object.entries(skills).map(([category, techs]) => (
        <div class="skill-category">
          <Typography component="h3" size="medium" variant="title" bottomGutter="small">
            {category}
          </Typography>
          <div class="skill-tags">
            {techs.map((tech) => (
              <Tag type={tech}>{tech}</Tag>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section id="education" title="Education & Certifications">
    <div class="education-content">
      <div class="education-item">
        <Typography component="h3" size="medium" variant="title">
          Bachelor of Science in Computer Science
        </Typography>
        <Typography size="medium" variant="body" class="institution">
          Western Kentucky University
        </Typography>
        <Typography size="small" variant="body" class="year">
          2019
        </Typography>
      </div>
    </div>
  </Section>
</Layout>

<style>
  .about-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-content p {
    margin-bottom: 1.5rem;
  }

  .experience-timeline {
    max-width: 800px;
    margin: 0 auto;
  }

  .experience-item {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border-radius: var(--dlh-theme-shape-corner-medium);
    background: var(--dlh-theme-color-surface-container);
  }

  .experience-header {
    margin-bottom: 1rem;
  }

  .company {
    color: var(--dlh-theme-color-primary);
    font-weight: 600;
  }

  .duration {
    color: var(--dlh-theme-color-on-surface-variant);
    font-style: italic;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .skill-category {
    padding: 1.5rem;
    border-radius: var(--dlh-theme-shape-corner-medium);
    background: var(--dlh-theme-color-surface-container);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .education-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .education-item {
    padding: 1.5rem;
    border-radius: var(--dlh-theme-shape-corner-medium);
    background: var(--dlh-theme-color-surface-container);
  }

  .institution {
    color: var(--dlh-theme-color-primary);
    font-weight: 600;
  }

  .year {
    color: var(--dlh-theme-color-on-surface-variant);
  }
</style>