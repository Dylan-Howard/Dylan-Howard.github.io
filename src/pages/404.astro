---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArrowLink from '../components/ArrowLink.astro';
---

<BaseLayout title="404 — Dylan Howard" description="Page not found.">
  <Header />

  <main class="not-found">
    <div class="container">
      <div class="not-found__inner">
        <span class="section-label">404</span>
        <h1 class="not-found__heading">Nothing here.</h1>
        <p class="not-found__sub">
          The page you're looking for doesn't exist — or was moved.
        </p>
        <ArrowLink href="/" label="Back to home" direction="left" />
      </div>
    </div>

    <span class="not-found__deco" aria-hidden="true">404</span>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found {
    position: relative;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: var(--space-20);
  }

  .not-found__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .not-found__heading {
    font-size: clamp(var(--text-4xl), 8vw, var(--text-5xl));
    font-weight: 300;
    letter-spacing: -0.03em;
  }

  .not-found__sub {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--ink-soft);
    font-size: var(--text-md);
    max-width: 36ch;
  }

  .not-found__deco {
    position: absolute;
    top: 50%;
    right: -0.05em;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(10rem, 28vw, 22rem);
    font-weight: 300;
    color: transparent;
    -webkit-text-stroke: 1px var(--rule);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    opacity: 0.4;
  }
</style>
