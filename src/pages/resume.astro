---
// src/pages/resume.astro
// Renders the resume MDX content through ResumeLayout.
// The content lives in src/content/resume/index.mdx so it's
// editable without touching any component or page file.
import { getCollection, render } from 'astro:content';
import ResumeLayout from '../layouts/ResumeLayout.astro';

const entries = await getCollection('resume');
const entry   = entries[0]; // only one resume entry

if (!entry) {
  throw new Error('No resume content found in src/content/resume/');
}

const { Content } = await render(entry);
const { title, description, pdfUrl, lastUpdated } = entry.data;
---

<ResumeLayout {title} {description} {pdfUrl} {lastUpdated}>
  <Content />
</ResumeLayout>
